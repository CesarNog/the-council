# Groq — inference (free tier, sem cartão)
# console.groq.com/keys
GROQ_API_KEY=gsk_...

# Cloudflare KV — persistencia de resultados (/r/:id) e rate limit
# dash.cloudflare.com > My Profile > API Tokens > template "Edit Cloudflare Workers"
CLOUDFLARE_API_TOKEN=cfut_...
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_KV_NAMESPACE_ID=...

# Sessao propria (cookie HMAC-assinado) — gerar com: openssl rand -base64 32
SESSION_SECRET=...

# Google OAuth — console.cloud.google.com > APIs & Services > Credentials > OAuth Client ID (Web application)
# Authorized JavaScript origins precisa incluir o dominio de producao.
# Mesmo valor nas duas vars: GOOGLE_CLIENT_ID (backend, verifica audience) e VITE_GOOGLE_CLIENT_ID (frontend, embutido no bundle no build — nao e secreto).
GOOGLE_CLIENT_ID=490082823324-lt2mg0fthak0k6p90e8h48f6h2ha86kl.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=490082823324-lt2mg0fthak0k6p90e8h48f6h2ha86kl.apps.googleusercontent.com

# TTS — sintetizador de voz (opcional; sem nenhuma das duas vars abaixo /api/tts retorna 503
# e o app usa a Web Speech API do browser como fallback)
#
# OpenAI TTS (primário, recomendado) — platform.openai.com/api-keys
# Usa gpt-4o-mini-tts com 9 vozes mapeadas por persona; suporta en/pt/es/zh nativamente.
OPENAI_API_KEY=sk-...
#
# Gemini TTS (fallback) — aistudio.google.com/apikey
# Usa gemini-2.5-flash-tts. Ativado se OPENAI_API_KEY nao estiver definido, ou como
# fallback caso a chamada OpenAI falhe.
GEMINI_TTS_API_KEY=AIza...

# Hotjar — heatmaps & session recordings (optional)
# hotjar.com > Settings > Tracking Code — get your Site ID
# Only loaded in production after analytics consent is granted.
VITE_HOTJAR_ID=
VITE_HOTJAR_VERSION=6

# Google AdSense — adsense.google.com > My Sites > Get code
# Publisher ID format: ca-pub-XXXXXXXXXXXXXXXX
# Only injected in production after advertising consent is granted.
VITE_ADSENSE_PUBLISHER_ID=

# Clerk — optional; when set, replaces Google GSI sign-in (dashboard.clerk.com)
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# Supabase — optional production database (supabase.com)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Upstash Redis — optional atomic rate limiting (upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PostHog — optional product analytics (consent-gated)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — optional error tracking
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Resend — optional transactional email
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Pinecone — optional vector memory (future)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Site URL — canonical links, OG, share URLs
VITE_SITE_URL=

# Stripe — optional subscriptions (future)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
