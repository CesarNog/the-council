# Groq — inference (free tier, sem cartão)
# console.groq.com/keys
GROQ_API_KEY=gsk_...

# Cloudflare KV — persistencia de resultados (/r/:id) e rate limit
# dash.cloudflare.com > My Profile > API Tokens > template "Edit Cloudflare Workers"
CLOUDFLARE_API_TOKEN=cfut_...
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_KV_NAMESPACE_ID=...

# Sessao propria (cookie HMAC-assinado) — gerar com: openssl rand -base64 32
SESSION_SECRET=...

# Google OAuth — console.cloud.google.com > APIs & Services > Credentials > OAuth Client ID (Web application)
# Authorized JavaScript origins precisa incluir o dominio de producao.
# Mesmo valor nas duas vars: GOOGLE_CLIENT_ID (backend, verifica audience) e VITE_GOOGLE_CLIENT_ID (frontend, embutido no bundle no build — nao e secreto).
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# Gemini TTS — aistudio.google.com/apikey
# Usado por api/tts.js para sintetizar fala via gemini-2.5-flash-preview-tts.
# Sem esta var, /api/tts retorna 503 e o app cai de volta para a Web Speech API do browser.
GEMINI_TTS_API_KEY=AIza...
